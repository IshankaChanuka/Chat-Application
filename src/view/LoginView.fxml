<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="loginAnconepane" prefHeight="399.0" prefWidth="614.0" style="-fx-background-color: WHITE;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
   <children>
      <Label layoutX="214.0" layoutY="150.0" text="Welcome to Chat Plus" textFill="#121212">
         <font>
            <Font name="Microsoft JhengHei UI" size="19.0" />
         </font>
      </Label>
      <TextField fx:id="txtUsername" layoutX="98.0" layoutY="224.0" prefHeight="55.0" prefWidth="418.0" promptText="Enter User Username" style="-fx-border-color: #121212;">
         <font>
            <Font size="17.0" />
         </font>
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
      </TextField>
      <Button fx:id="btnLogin" layoutX="98.0" layoutY="298.0" mnemonicParsing="false" onAction="#btnloginOnAction" prefHeight="55.0" prefWidth="418.0" style="-fx-background-color: #852CA5;" text="LOGIN" textFill="WHITE">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Label fx:id="lblerror" layoutX="98.0" layoutY="200.0" prefHeight="21.0" prefWidth="188.0" textFill="RED">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <ImageView fitHeight="121.0" fitWidth="133.0" layoutX="247.0" layoutY="28.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assests/icon/chat.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
